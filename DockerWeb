FROM rust:alpine3.22 as build

# create a new empty shell project
RUN rustup toolchain install nightly --allow-downgrade --profile minimal --component clippy
RUN rustup override set nightly
RUN USER=root cargo new --bin worstbird
WORKDIR /worstbird
RUN apk add pkgconfig openssl-dev libc-dev libpq-dev


# copy over your manifests
COPY ./Cargo.lock ./Cargo.lock
# COPY ./Cargo.toml ./Cargo.toml

# this build step will cache your dependencies
RUN RUSTFLAGS="-C target-feature=-crt-static" cargo build --release 
RUN rm -rf src/

COPY ./ ./

# copy your source tree
RUN mkdir -p ./templates
COPY ./templates ./templates

# build for release
RUN ls target/release/deps/
RUN rm ./target/release/deps/worstbird*
RUN RUSTFLAGS="-C target-feature=-crt-static" cargo build --release -p worstbird_http


FROM alpine:latest
RUN apk update &&  apk add openssl libgcc ca-certificates libpq-dev

COPY --from=build /worstbird/target/release/worstbird_http .

#RUN mkdir -p ./www
#COPY ./www ./www
RUN mkdir -p ./templates
COPY ./templates ./templates

CMD ["./worstbird_http"]
